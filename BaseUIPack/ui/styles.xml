<styles>
    <variable name="accentColor" value="@settings.accentColor" />
    <variable name="cornerRadius" value="@settings.roundedCorners ? '16dp' : '0dp'" />
    <variable name="blurEnabled" value="@settings.blurBackground" />

    <style name="HeaderStyle">
        <property name="textColor">#FFFFFF</property>
        <property name="fontSize">18sp</property>
    </style>

    <style name="CardStyle">
        <property name="background">@variable.accentColor</property>
        <property name="cornerRadius">@variable.cornerRadius</property>
        <property name="blur">@variable.blurEnabled</property>
    </style>
</styles>
